# ============================================================
# .env.example — Copy this file to .env and fill in your values
# NEVER commit the real .env file (it's in .gitignore)
# ============================================================

# ── PostgreSQL (users table / authentication) ──────────────
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DBNAME

# ── MongoDB (screenshots / raw_samples) ───────────────────
MONGODB_URL=mongodb://USER:PASSWORD@HOST:PORT/
MONGODB_DB_NAME=ai_assistant

# ── CORS (optional — defaults to localhost:3000) ───────────
# ALLOWED_ORIGINS=https://your-frontend.com,http://localhost:3000
