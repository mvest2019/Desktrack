# ============================================================
# .env.example — TEMPLATE ONLY. No real credentials here.
# ============================================================
# USAGE:
#   1. Copy this file:   cp .env.example .env.staging
#   2. Fill in real values
#   3. NEVER commit .env.staging to git
#      Add this line to .gitignore:  .env.staging
# ============================================================

# ── PostgreSQL (users table / authentication) ──────────────
# Format: postgresql://username:password@host/database
POSTGRES_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASS@YOUR_SERVER_IP/YOUR_DB_NAME

# ── MongoDB (screenshots / raw_samples) ───────────────────
MONGODB_URL=mongodb://YOUR_MONGO_USER:YOUR_MONGO_PASS@YOUR_SERVER_IP:27017/
MONGODB_DB_NAME=YOUR_DB_NAME

# ── CORS: frontend URLs allowed to call this API ───────────
# Comma-separated, no trailing slash
# Example: https://syntra.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── App environment ─────────────────────────────────────────
APP_ENV=staging
